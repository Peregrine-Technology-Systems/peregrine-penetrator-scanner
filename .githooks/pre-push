#!/bin/bash
# Pre-push hook template - Comprehensive quality gates
# Ensures code quality before pushing to remote repositories
# Copy to .githooks/pre-push and link from .git/hooks/

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Function to print colored output
print_status() {
    echo -e "${2}${1}${NC}"
}

print_error() {
    print_status "❌ $1" "$RED"
}

print_success() {
    print_status "✅ $1" "$GREEN"
}

print_info() {
    print_status "ℹ️  $1" "$BLUE"
}

print_warning() {
    print_status "⚠️  $1" "$YELLOW"
}

# Function to prompt for bypass confirmation
confirm_bypass() {
    print_warning "Attempting to bypass pre-push quality checks!"
    echo ""
    echo -e "${YELLOW}This would skip the following FULL CODEBASE quality checks:${NC}"
    echo "  • Test file verification"
    echo "  • FULL test suite execution (100% pass requirement)"
    echo "  • FULL project code coverage (90% minimum)"
    echo "  • Code quality analysis"
    echo "  • Type checking/static analysis"
    echo "  • Code formatting validation"
    echo ""
    echo -e "${RED}⚠️  WARNING: Bypassing these checks may introduce bugs or break CI/CD${NC}"
    echo ""
    echo -e "${YELLOW}Are you ABSOLUTELY SURE you want to bypass quality checks?${NC}"
    echo -e "Type ${RED}BYPASS${NC} (in caps) to confirm, or press Enter to cancel: "

    read -r response < /dev/tty

    if [ "$response" != "BYPASS" ]; then
        print_error "Bypass cancelled. Quality checks will run as normal."
        exit 1
    else
        print_warning "Quality checks bypassed by user confirmation"
        echo -e "${RED}Note: This bypass has been logged${NC}"
        # Log the bypass for audit purposes
        echo "$(date '+%Y-%m-%d %H:%M:%S') - Pre-push checks bypassed by user on branch: $CURRENT_BRANCH" >> .git/pre-push-bypass.log
        exit 0
    fi
}

# Detect project type
detect_project_type() {
    if [ -f "mix.exs" ]; then
        echo "elixir"
    elif [ -f "package.json" ]; then
        echo "nodejs"
    elif [ -f "requirements.txt" ] || [ -f "setup.py" ]; then
        echo "python"
    elif [ -f "Gemfile" ]; then
        echo "ruby"
    elif [ -f "go.mod" ]; then
        echo "go"
    elif [ -f "Cargo.toml" ]; then
        echo "rust"
    else
        echo "unknown"
    fi
}

# Check if we should prompt for bypass
if [ -n "$BYPASS_PUSH_CHECKS" ]; then
    confirm_bypass
fi

# Get current branch
CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD)

# Skip checks for staging and main branches (these should receive already-validated code)
if [[ "$CURRENT_BRANCH" == "staging" ]] || [[ "$CURRENT_BRANCH" == "main" ]] || [[ "$CURRENT_BRANCH" == "master" ]]; then
    print_info "On $CURRENT_BRANCH branch, skipping pre-push checks"
    exit 0
fi

print_info "Running pre-push checks for branch: $CURRENT_BRANCH"

# Check if CI has already passed for this branch
check_ci_status() {
    local branch=$1
    local latest_sha=$(git rev-parse HEAD)

    # Check if gh CLI is available
    if command -v gh >/dev/null 2>&1; then
        # Check if there's an open PR for this branch
        local pr_number=$(gh pr list --head "$branch" --state open --json number --jq '.[0].number // empty' 2>/dev/null || echo "")

        if [ -n "$pr_number" ]; then
            print_info "Found PR #$pr_number for branch $branch"

            # Check CI status for the PR
            local checks=$(gh pr checks "$pr_number" --json name,status,conclusion 2>/dev/null || echo "")

            if [ -n "$checks" ]; then
                local all_passed=$(echo "$checks" | jq -r '[.[] | select(.status == "completed" and .conclusion == "success")] | length')
                local total_checks=$(echo "$checks" | jq -r 'length')

                if [ "$all_passed" = "$total_checks" ] && [ "$total_checks" -gt 0 ]; then
                    print_success "All CI checks have passed on GitHub ($all_passed/$total_checks)"
                    print_info "Skipping local checks since CI already verified the code"
                    exit 0
                fi
            fi
        fi
    fi

    return 1
}

# Try to check CI status
if check_ci_status "$CURRENT_BRANCH"; then
    exit 0
fi

PROJECT_TYPE=$(detect_project_type)
print_info "Project type: $PROJECT_TYPE"

# Get list of changed files
while read local_ref local_sha remote_ref remote_sha; do
    if [ "$local_sha" = "0000000000000000000000000000000000000000" ]; then
        # Branch is being deleted
        exit 0
    fi

    # Extract the branch name from remote_ref
    REMOTE_BRANCH=${remote_ref#refs/heads/}

    # Skip checks for staging and main branches
    if [[ "$REMOTE_BRANCH" == "staging" ]] || [[ "$REMOTE_BRANCH" == "main" ]] || [[ "$REMOTE_BRANCH" == "master" ]]; then
        continue
    fi

    print_info "Checking changes for push to $REMOTE_BRANCH"

    # Get the base branch
    BASE_BRANCH="development"
    if ! git rev-parse --verify origin/$BASE_BRANCH >/dev/null 2>&1; then
        BASE_BRANCH="main"
        if ! git rev-parse --verify origin/$BASE_BRANCH >/dev/null 2>&1; then
            BASE_BRANCH="master"
        fi
    fi

    # Get list of changed files
    if git rev-parse --verify origin/$BASE_BRANCH >/dev/null 2>&1; then
        CHANGED_FILES=$(git diff --name-only origin/$BASE_BRANCH..HEAD || git diff --name-only HEAD~5..HEAD)
    else
        CHANGED_FILES=$(git diff --name-only HEAD~3..HEAD)
    fi

    # Project-specific checks
    case "$PROJECT_TYPE" in
        elixir)
            # Elixir/Phoenix checks
            print_info "Running Elixir/Phoenix quality checks..."

            # Check 1: Test file verification
            print_info "1. Checking for test files..."
            ELIXIR_FILES=$(echo "$CHANGED_FILES" | grep -E '\.ex$' | grep '^lib/' || true)
            MISSING_TESTS=""

            for file in $ELIXIR_FILES; do
                test_file=$(echo "$file" | sed 's|^lib/|test/|' | sed 's|\.ex$|_test.exs|')
                if [ ! -f "$test_file" ]; then
                    MISSING_TESTS="$MISSING_TESTS\n  $file -> $test_file (missing)"
                fi
            done

            if [ -n "$MISSING_TESTS" ]; then
                print_error "Missing test files for changed source files:"
                echo -e "$MISSING_TESTS"
                exit 1
            fi

            # Check 2: Run FULL test suite
            print_info "2. Running FULL test suite..."
            if ! MIX_ENV=test mix test --max-failures=1; then
                print_error "Tests failed! ALL tests must pass before pushing"
                exit 1
            fi
            print_success "All tests pass 100%"

            # Check 3: Code coverage
            print_info "3. Checking code coverage..."
            mix coveralls.json >/dev/null 2>&1
            if [ -f "cover/excoveralls.json" ]; then
                COVERAGE=$(cat cover/excoveralls.json | jq -r '.percentage')
                if (( $(echo "$COVERAGE < 90" | bc -l) )); then
                    print_error "Coverage $COVERAGE% is below required 90%"
                    exit 1
                fi
                print_success "Coverage: $COVERAGE%"
            fi

            # Check 4: Credo
            print_info "4. Running Credo strict mode..."
            if ! mix credo --strict; then
                print_error "Credo found issues!"
                exit 1
            fi

            # Check 5: Dialyzer
            print_info "5. Running Dialyzer..."
            if [ ! -f "priv/plts/dialyzer.plt" ]; then
                mix dialyzer --plt
            fi
            if ! mix dialyzer; then
                print_error "Dialyzer found issues!"
                exit 1
            fi

            # Check 6: Formatting
            print_info "6. Checking formatting..."
            if ! mix format --check-formatted; then
                print_error "Code not properly formatted! Run: mix format"
                exit 1
            fi
            ;;

        nodejs)
            # Node.js checks
            print_info "Running Node.js quality checks..."

            # Check 1: Tests
            print_info "1. Running test suite..."
            if [ -f "package.json" ] && grep -q '"test"' package.json; then
                if ! npm test; then
                    print_error "Tests failed!"
                    exit 1
                fi
            fi

            # Check 2: Linting
            print_info "2. Running linter..."
            if [ -f "package.json" ] && grep -q '"lint"' package.json; then
                if ! npm run lint; then
                    print_error "Linting failed!"
                    exit 1
                fi
            fi

            # Check 3: Type checking
            print_info "3. Type checking..."
            if [ -f "tsconfig.json" ]; then
                if ! npx tsc --noEmit; then
                    print_error "TypeScript errors found!"
                    exit 1
                fi
            fi

            # Check 4: Coverage
            print_info "4. Checking coverage..."
            if [ -f "package.json" ] && grep -q '"coverage"' package.json; then
                npm run coverage >/dev/null 2>&1
                # Parse coverage report if available
            fi
            ;;

        python)
            # Python checks
            print_info "Running Python quality checks..."

            # Check 1: Tests
            print_info "1. Running test suite..."
            if command -v pytest >/dev/null 2>&1; then
                if ! pytest; then
                    print_error "Tests failed!"
                    exit 1
                fi
            fi

            # Check 2: Linting
            print_info "2. Running linters..."
            if command -v flake8 >/dev/null 2>&1; then
                if ! flake8 .; then
                    print_error "Flake8 found issues!"
                    exit 1
                fi
            fi

            if command -v pylint >/dev/null 2>&1; then
                if ! pylint **/*.py; then
                    print_warning "Pylint found issues"
                fi
            fi

            # Check 3: Type checking
            print_info "3. Type checking..."
            if command -v mypy >/dev/null 2>&1; then
                if ! mypy .; then
                    print_error "Type errors found!"
                    exit 1
                fi
            fi

            # Check 4: Coverage
            print_info "4. Checking coverage..."
            if command -v coverage >/dev/null 2>&1; then
                coverage run -m pytest >/dev/null 2>&1
                COVERAGE=$(coverage report | tail -1 | awk '{print $4}' | sed 's/%//')
                if [ -n "$COVERAGE" ] && (( $(echo "$COVERAGE < 90" | bc -l) )); then
                    print_error "Coverage $COVERAGE% is below required 90%"
                    exit 1
                fi
            fi
            ;;

        ruby)
            # Ruby checks
            print_info "Running Ruby quality checks..."

            # Check 1: Tests
            print_info "1. Running full test suite..."
            if ! bundle exec rspec --format progress; then
                print_error "Tests failed!"
                exit 1
            fi
            print_success "All tests pass"

            # Check 2: Coverage (90% minimum)
            print_info "2. Checking code coverage..."
            if [ -f "coverage/.last_run.json" ]; then
                COVERAGE=$(ruby -rjson -e 'puts JSON.parse(File.read("coverage/.last_run.json"))["result"]["line"]')
                COVERAGE_INT=${COVERAGE%.*}
                if [ "$COVERAGE_INT" -lt 90 ]; then
                    print_error "Coverage ${COVERAGE}% is below 90% minimum"
                    exit 1
                fi
                print_success "Coverage: ${COVERAGE}%"
            else
                print_warning "No coverage data found — skipping coverage check"
            fi

            # Check 3: RuboCop
            print_info "3. Running RuboCop..."
            if ! bundle exec rubocop --parallel; then
                print_error "RuboCop found issues!"
                exit 1
            fi
            print_success "RuboCop clean"
            ;;

        go)
            # Go checks
            print_info "Running Go quality checks..."

            # Check 1: Tests
            print_info "1. Running test suite..."
            if ! go test ./...; then
                print_error "Tests failed!"
                exit 1
            fi

            # Check 2: Vet
            print_info "2. Running go vet..."
            if ! go vet ./...; then
                print_error "go vet found issues!"
                exit 1
            fi

            # Check 3: Formatting
            print_info "3. Checking formatting..."
            if [ -n "$(gofmt -l .)" ]; then
                print_error "Code not properly formatted! Run: gofmt -w ."
                exit 1
            fi
            ;;

        rust)
            # Rust checks
            print_info "Running Rust quality checks..."

            # Check 1: Tests
            print_info "1. Running test suite..."
            if ! cargo test; then
                print_error "Tests failed!"
                exit 1
            fi

            # Check 2: Clippy
            print_info "2. Running clippy..."
            if ! cargo clippy -- -D warnings; then
                print_error "Clippy found issues!"
                exit 1
            fi

            # Check 3: Formatting
            print_info "3. Checking formatting..."
            if ! cargo fmt -- --check; then
                print_error "Code not properly formatted! Run: cargo fmt"
                exit 1
            fi
            ;;

        *)
            print_warning "Unknown project type. Running basic checks only..."
            ;;
    esac

    print_success "🎉 All pre-push checks passed!"
    print_info "Ready to push to $REMOTE_BRANCH"

done

exit 0