<%# Methodology Partial — renders test methodology documentation
     Variables expected:
       scan     — Scan model instance (uses scan.profile for detail level)
       brand    — Hash with :primary_color, :accent_color
     The "thorough" profile renders the full detailed test matrix;
     other profiles show the high-level summary only.
%>
<%
  show_detailed = (scan.profile == "thorough")
  tool_descriptions = [
    {
      name: "OWASP ZAP",
      category: "DAST Scanner",
      icon_letter: "Z",
      color: "#2563eb",
      summary: "Full dynamic application security testing — actively crawls the target application, " \
               "mapping all reachable endpoints and testing each for cross-site scripting (XSS), " \
               "cross-site request forgery (CSRF), SQL injection, security misconfigurations, " \
               "and information disclosure vulnerabilities. Industry-standard OWASP-aligned scanner " \
               "providing broad coverage of the OWASP Top 10.",
      owasp_mapping: [
        { id: "A01", name: "Broken Access Control", tests: "Path traversal, forced browsing, insecure direct object references (IDOR), missing function-level access controls, CORS misconfiguration allowing unauthorized cross-origin access" },
        { id: "A02", name: "Cryptographic Failures", tests: "Insecure transport (HTTP vs HTTPS), weak TLS configurations, mixed content warnings, sensitive data transmitted in cleartext, missing HSTS headers" },
        { id: "A03", name: "Injection", tests: "Reflected XSS, stored XSS, DOM-based XSS, SQL injection (error-based, blind), OS command injection, LDAP injection, header injection, CRLF injection" },
        { id: "A05", name: "Security Misconfiguration", tests: "Missing security headers (CSP, X-Frame-Options, X-Content-Type-Options), directory listing enabled, verbose error messages, default configurations, CORS policy misconfigurations" },
        { id: "A07", name: "Identification & Authentication Failures", tests: "Session management weaknesses, insecure cookie flags (missing Secure, HttpOnly, SameSite), login form over HTTP, session fixation, weak session identifiers" },
        { id: "A09", name: "Security Logging & Monitoring Failures", tests: "Information leakage in HTTP responses, stack traces in error pages, server version disclosure, internal path disclosure, debug information exposure" }
      ]
    },
    {
      name: "Nuclei",
      category: "CVE & Template Scanner",
      icon_letter: "N",
      color: "#7c3aed",
      summary: "Template-based vulnerability scanning against 11,000+ known vulnerability signatures (CVEs). " \
               "Checks for known exploits in deployed software, misconfigurations, default credentials, " \
               "exposed administrative panels, and technology-specific vulnerabilities. Templates are " \
               "continuously updated by the security community.",
      detail_categories: [
        { name: "CVE Detection", description: "Scans against known CVEs organized by year range and severity. Covers critical and high-severity CVEs from 2017-present with emphasis on actively exploited vulnerabilities." },
        { name: "Technology-Specific", description: "Targeted checks for Apache HTTP Server, nginx, WordPress (core + plugins), Joomla, Drupal, Tomcat, IIS, PHP frameworks, Node.js, and 200+ other technology stacks." },
        { name: "Default Credentials", description: "Tests for default username/password combinations on admin panels, databases, management interfaces, CI/CD tools, monitoring dashboards, and cloud service consoles." },
        { name: "Exposed Panels & Files", description: "Detects exposed admin panels (phpMyAdmin, Adminer, cPanel), configuration files (.env, web.config, wp-config.php), backup files, and source code repositories (.git, .svn)." },
        { name: "Cloud Misconfigurations", description: "Checks for AWS S3 bucket misconfigurations, Azure Blob storage exposure, GCP service account key leaks, exposed cloud metadata endpoints (169.254.169.254), and misconfigured CDN origins." },
        { name: "Network Services", description: "DNS zone transfer tests, mail server open relay checks, SSL/TLS certificate validation, expired certificates, and weak cipher suite detection." }
      ]
    },
    {
      name: "sqlmap",
      category: "SQL Injection Specialist",
      icon_letter: "S",
      color: "#dc2626",
      summary: "Specialized SQL injection detection and exploitation testing tool. Systematically tests " \
               "all discovered URL parameters, form fields, and HTTP headers for blind, error-based, " \
               "UNION-based, stacked query, and time-based SQL injection techniques across all major " \
               "database management systems.",
      detail_categories: [
        { name: "Boolean-Based Blind", description: "Infers database content by analyzing true/false response differences. Tests each parameter with crafted boolean conditions to detect injection points invisible in normal responses." },
        { name: "Error-Based", description: "Triggers database error messages to extract data. Tests for verbose SQL errors in MySQL, PostgreSQL, MSSQL, Oracle, and SQLite that reveal schema information." },
        { name: "UNION-Based", description: "Appends UNION SELECT statements to extract data from other tables. Automatically determines column count and data types for successful data exfiltration." },
        { name: "Stacked Queries", description: "Tests for ability to execute multiple SQL statements in a single request. Critical for detecting potential data modification or administrative command execution." },
        { name: "Time-Based Blind", description: "Uses database-specific time delay functions (SLEEP, WAITFOR, pg_sleep) to infer data when no visible output differences exist. Most thorough but slowest technique." },
        { name: "Out-of-Band", description: "Tests for DNS and HTTP-based data exfiltration channels when direct response analysis is not possible. Uses callback techniques for databases that support network operations." }
      ]
    },
    {
      name: "ffuf",
      category: "Content Discovery",
      icon_letter: "F",
      color: "#059669",
      summary: "High-speed web fuzzer for endpoint and directory discovery. Identifies hidden paths, " \
               "backup files, administrative panels, undocumented API endpoints, and sensitive files " \
               "using multiple curated wordlists. Capable of discovering attack surface invisible to " \
               "crawlers and traditional scanners.",
      detail_categories: [
        { name: "Directory Enumeration", description: "Brute-force discovery of directories and paths using curated wordlists (common.txt, directory-list-2.3-medium.txt). Identifies admin directories, upload folders, and hidden application areas." },
        { name: "File Discovery", description: "Tests for common sensitive files: backup archives (.bak, .old, .tar.gz), configuration files (web.config, .htaccess, .env), database dumps (.sql), and documentation files." },
        { name: "API Endpoint Discovery", description: "Fuzzes common API path patterns (/api/v1/, /graphql, /rest/) to discover undocumented endpoints, internal APIs, and debug interfaces that may lack proper authentication." },
        { name: "Virtual Host Discovery", description: "Tests for additional virtual hosts and subdomains served by the same web server that may host development, staging, or internal applications." },
        { name: "Parameter Discovery", description: "Fuzzes URL parameters and HTTP headers to discover hidden functionality, debug parameters, and administrative overrides." }
      ]
    },
    {
      name: "Nikto",
      category: "Server Audit",
      icon_letter: "K",
      color: "#d97706",
      summary: "Comprehensive web server misconfiguration scanner. Performs 6,700+ checks for outdated " \
               "server software, dangerous HTTP methods, insecure headers, default installation files, " \
               "and known server vulnerabilities. Provides broad server-level security posture assessment " \
               "complementing application-level testing.",
      detail_categories: [
        { name: "Server Software Versions", description: "Identifies web server software and version (Apache, nginx, IIS, LiteSpeed), application frameworks, and backend languages. Cross-references against known CVE databases for version-specific vulnerabilities." },
        { name: "Dangerous HTTP Methods", description: "Tests for enabled HTTP methods that should be disabled: PUT (file upload), DELETE (file removal), TRACE (XST attacks), OPTIONS (information disclosure), and WebDAV methods (PROPFIND, COPY, MOVE)." },
        { name: "Security Headers", description: "Validates presence and configuration of security headers: Content-Security-Policy, X-Frame-Options, X-Content-Type-Options, Referrer-Policy, Permissions-Policy, and Strict-Transport-Security." },
        { name: "Default Files & Directories", description: "Checks for default installation files, sample applications, documentation pages, and test scripts left on production servers that may reveal sensitive information or provide attack vectors." },
        { name: "SSL/TLS Configuration", description: "Evaluates SSL/TLS certificate validity, protocol versions supported (SSLv3, TLS 1.0/1.1 deprecation), cipher suite strength, and certificate chain integrity." },
        { name: "CGI Vulnerabilities", description: "Tests for known CGI script vulnerabilities including Shellshock (CVE-2014-6271), common CGI path traversals, and script injection in legacy CGI applications." }
      ]
    }
  ]
%>

<div class="methodology-section">
  <div class="methodology-intro">
    <p>This assessment employed a multi-layered scanning methodology combining five specialized security testing
    tools orchestrated in three phases: discovery, active scanning, and targeted exploitation testing.
    Results are aggregated, deduplicated using SHA-256 fingerprinting, enriched with CVE intelligence
    (NVD, CISA KEV, EPSS), and analyzed using AI-assisted triage to prioritize remediation efforts.</p>
  </div>

  <!-- Phase Overview -->
  <div class="methodology-phases">
    <div class="phase-card">
      <div class="phase-number">1</div>
      <div class="phase-content">
        <div class="phase-title">Discovery Phase</div>
        <div class="phase-tools">ffuf + Nikto</div>
        <div class="phase-desc">Content discovery and server audit run in parallel to map the attack surface,
        identifying hidden endpoints, server misconfigurations, and technology stack details.</div>
      </div>
    </div>
    <div class="phase-connector"></div>
    <div class="phase-card">
      <div class="phase-number">2</div>
      <div class="phase-content">
        <div class="phase-title">Active Scanning Phase</div>
        <div class="phase-tools">OWASP ZAP</div>
        <div class="phase-desc">Full DAST scan with active crawling and attack injection. Leverages discovery
        results to maximize coverage across all identified endpoints and parameters.</div>
      </div>
    </div>
    <div class="phase-connector"></div>
    <div class="phase-card">
      <div class="phase-number">3</div>
      <div class="phase-content">
        <div class="phase-title">Targeted Testing Phase</div>
        <div class="phase-tools">Nuclei + sqlmap</div>
        <div class="phase-desc">Template-based CVE scanning and specialized SQL injection testing run in
        parallel, targeting specific vulnerabilities and injection points identified in earlier phases.</div>
      </div>
    </div>
  </div>

  <!-- Tool Summary Table -->
  <div class="methodology-table-wrap">
    <table class="methodology-table">
      <thead>
        <tr>
          <th>Tool</th>
          <th>Category</th>
          <th>Description</th>
        </tr>
      </thead>
      <tbody>
        <% tool_descriptions.each do |tool| %>
          <tr>
            <td>
              <div class="tool-name-badge" style="--tool-color: <%= tool[:color] %>;">
                <span class="tool-icon"><%= tool[:icon_letter] %></span>
                <span><%= tool[:name] %></span>
              </div>
            </td>
            <td><span class="tool-category-tag"><%= tool[:category] %></span></td>
            <td class="tool-desc-cell"><%= tool[:summary] %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <!-- AI & Intelligence Enrichment -->
  <div class="methodology-enrichment">
    <div class="enrichment-card">
      <div class="enrichment-icon">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M12 2a4 4 0 0 1 4 4v2a4 4 0 0 1-8 0V6a4 4 0 0 1 4-4z"/>
          <path d="M16 14a6 6 0 0 1-12 0"/>
          <circle cx="12" cy="20" r="2"/>
          <path d="M12 16v2"/>
        </svg>
      </div>
      <div class="enrichment-content">
        <div class="enrichment-title">AI-Assisted Analysis</div>
        <div class="enrichment-desc">All findings are analyzed by Claude (Anthropic) for contextual triage,
        false-positive assessment, remediation prioritization, and executive summary generation.
        AI assessments consider the specific technology context, finding severity, and potential
        business impact.</div>
      </div>
    </div>
    <div class="enrichment-card">
      <div class="enrichment-icon">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
        </svg>
      </div>
      <div class="enrichment-content">
        <div class="enrichment-title">CVE Intelligence Enrichment</div>
        <div class="enrichment-desc">Findings are enriched with data from the National Vulnerability Database (NVD)
        for CVSS scores, CISA Known Exploited Vulnerabilities (KEV) catalog for active exploitation status,
        EPSS (Exploit Prediction Scoring System) for probability of exploitation in the wild, and
        OSV (Open Source Vulnerabilities) for open-source component risks.</div>
      </div>
    </div>
  </div>

  <% if show_detailed %>
    <!-- Detailed Test Matrix (thorough profile only) -->
    <div class="methodology-detail-header">
      <h3>Detailed Test Matrix</h3>
      <p>The following sections detail the specific test categories executed by each tool,
      mapped to OWASP Top 10 (2021) where applicable.</p>
    </div>

    <% tool_descriptions.each do |tool| %>
      <details class="methodology-tool-detail" open>
        <summary>
          <span class="tool-name-badge" style="--tool-color: <%= tool[:color] %>;">
            <span class="tool-icon"><%= tool[:icon_letter] %></span>
            <span><%= tool[:name] %></span>
          </span>
          <span class="tool-category-label"><%= tool[:category] %></span>
        </summary>

        <div class="methodology-detail-body">
          <% if tool[:owasp_mapping] %>
            <table class="owasp-mapping-table">
              <thead>
                <tr>
                  <th style="width: 60px;">OWASP</th>
                  <th style="width: 200px;">Category</th>
                  <th>Tests Performed</th>
                </tr>
              </thead>
              <tbody>
                <% tool[:owasp_mapping].each do |mapping| %>
                  <tr>
                    <td><span class="owasp-id"><%= mapping[:id] %></span></td>
                    <td class="owasp-name"><%= mapping[:name] %></td>
                    <td><%= mapping[:tests] %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          <% end %>

          <% if tool[:detail_categories] %>
            <div class="detail-categories-grid">
              <% tool[:detail_categories].each do |cat| %>
                <div class="detail-category-card">
                  <div class="detail-category-name"><%= cat[:name] %></div>
                  <div class="detail-category-desc"><%= cat[:description] %></div>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      </details>
    <% end %>

    <!-- Deduplication & Fingerprinting -->
    <div class="methodology-subsection">
      <h4>Finding Deduplication</h4>
      <p>All findings are deduplicated using SHA-256 fingerprinting computed from the composite key of
      <code>source_tool + title + URL + parameter + CWE ID</code>. This eliminates redundant alerts
      when multiple tools detect the same underlying vulnerability, ensuring each unique finding
      is reported exactly once while preserving the most detailed evidence from each source.</p>
    </div>
  <% end %>
</div>
